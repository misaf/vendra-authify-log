{
	"name": "misaf/vendra-authify-log",
	"description": "",
	"license": "MIT",
	"type": "vendra-module",
	"keywords": [
		"laravel",
		"filamentphp",
		"authify",
		"log"
	],
	"authors": [
		{
			"name": "Ehsan Mahmoodi",
			"email": "misaf.1990@gmail.com",
			"role": "Developer"
		}
	],
	"require": {
		"php": "^8.3",
		"filament/filament": "^5.0",
		"illuminate/support": "^13.0",
		"misaf/laravel-authify-log": "^1.0",
		"misaf/vendra-support": "dev-master",
		"misaf/vendra-user": "dev-master",
		"misaf/filament-jalali": "^5.1",
		"spatie/eloquent-sortable": "^5.0",
		"spatie/laravel-package-tools": "^1.0"
	},
	"require-dev": {
		"fakerphp/faker": "^1.0",
		"larastan/larastan": "^3.0",
		"laravel/boost": "^2.0",
		"laravel/pint": "^1.0",
		"mockery/mockery": "^1.0",
		"nunomaduro/collision": "^8.0",
		"orchestra/testbench": "^10.0",
		"pestphp/pest": "^4.0",
		"pestphp/pest-plugin-laravel": "^4.0",
		"pestphp/pest-plugin-profanity": "^4.0",
		"pestphp/pest-plugin-type-coverage": "^4.0"
	},
	"minimum-stability": "stable",
	"prefer-stable": true,
	"autoload": {
		"psr-4": {
			"Misaf\\VendraAuthifyLog\\": "src/",
			"Misaf\\VendraAuthifyLog\\Database\\Factories\\": "database/factories/",
			"Misaf\\VendraAuthifyLog\\Database\\Seeders\\": "database/seeders/",
			"Misaf\\VendraAuthifyLog\\Tests\\": "tests/"
		}
	},
	"config": {
		"allow-plugins": {
			"pestphp/pest-plugin": true,
			"php-http/discovery": true
		},
		"optimize-autoloader": true,
		"preferred-install": "dist",
		"sort-packages": true
	},
	"extra": {
		"laravel": {
			"providers": [
				"Misaf\\VendraAuthifyLog\\Providers\\AuthifyLogServiceProvider"
			]
		}
	},
	"scripts": {
		"analyse": "vendor/bin/phpstan analyse",
		"format": "vendor/bin/pint",
		"test": "vendor/bin/pest",
		"test-coverage": "vendor/bin/pest --coverage"
	},
	"$schema": "https://getcomposer.org/schema.json"
}
